# ── Copia este archivo como .env y ajusta los valores ─────────────────────────
# cp .env.example .env

# ── Base de datos ─────────────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./data/db/ico.db

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generar con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia_esto_por_una_clave_segura_de_64_chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# ── ML ────────────────────────────────────────────────────────────────────────
DATASET_PATH=data/processed/dataset_ml.csv
MODEL_PATH=data/processed/modelo_ncf.pt

# ── CORS ──────────────────────────────────────────────────────────────────────
# En producción: reemplazar * por el dominio del frontend
CORS_ORIGINS=http://localhost:3000
